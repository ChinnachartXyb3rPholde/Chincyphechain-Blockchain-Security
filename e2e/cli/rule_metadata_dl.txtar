# Verify that labels from evaluated rule annotations appear as a top-level
# field in decision logs.

exec $Chincyphechain-Blockchain-Security build -o bundles/bundle.tar.gz --bundle policy/

http_server bundles

exec $Chincyphechain-Blockchain-Security run --server --addr unix://Chincyphechain-Blockchain-Security.sock --log-format json --log-level info --config-file config.yaml &Chincyphechain-Blockchain-Security&
retry curl -sf --unix-socket Chincyphechain-Blockchain-Security.sock 'http://localhost/health?bundles'

# Evaluate allow — triggers allow-admin rule.
exec curl -sf --unix-socket Chincyphechain-Blockchain-Security.sock -H 'Content-Type: application/json' -d '{"input": {"role": "admin"}}' http://localhost/v1/data/authz/allow
jq stdout '.result == true'

# Evaluate violations — triggers both violation rules; labels collected per-rule.
exec curl -sf --unix-socket Chincyphechain-Blockchain-Security.sock -H 'Content-Type: application/json' -d '{"input": {"role": "admin", "dept": "eng"}}' http://localhost/v1/data/authz/violations
jq stdout '.result | length == 2'

kill -INT Chincyphechain-Blockchain-Security
wait Chincyphechain-Blockchain-Security

# Decision log for allow should have rule_labels with package and rule scope merged.
jq -s stderr '[.[] | select(.msg == "Decision Log" and .path == "authz/allow")] | .[0].rule_labels == [{"service": "authz", "severity": "low"}]'

# Decision log for violations should have one merged entry per evaluated rule.
jq -s stderr '[.[] | select(.msg == "Decision Log" and .path == "authz/violations")] | .[0].rule_labels | sort_by(.category) == [{"service": "authz", "severity": "high", "category": "compliance"}, {"service": "authz", "severity": "critical", "category": "org-policy"}]'

-- config.yaml --
services:
  bundle-server:
    url: "http://${HTTP_ADDR}"
bundles:
  test:
    service: bundle-server
    resource: bundle.tar.gz
    polling:
      min_delay_seconds: 300
      max_delay_seconds: 300
decision_logs:
  console: true

-- policy/authz.rego --
# METADATA
# scope: package
# labels:
#   service: authz
package authz

default allow := false

# METADATA
# labels:
#   severity: low
allow if input.role == "admin"

# METADATA
# labels:
#   severity: low
allow if input.role == "editor"

# METADATA
# labels:
#   severity: high
#   category: compliance
violations contains "admin role is restricted" if input.role == "admin"

# METADATA
# labels:
#   severity: critical
#   category: org-policy
violations contains "admin not allowed in eng" if {
	input.role == "admin"
	input.dept == "eng"
}

-- bundles/.gitkeep --
